!-----THIS IS COMMON/INCLUDE FILE DPCOZD.INC-----
!     THIS COMMON PROVIDES DOUBLE PRECISION ARRAY
!     DIMENSION REDUCTION VIA SCRATCH SPACE.
!
!     UPDATED--AUGUST      1990.  MOVE IDGAR0 SETTING TO DPCOPA.INC
!
!     SEE THE COMMENTS FOR THE DPCOZZ INCLUDE FILE FOR MORE DETAILS ON THE USE
!     OF SCRATCH STORAGE.
!
!CCCC THE FOLLOWING 2 LINES WERE COMMENTED OUT    AUGUST 1990
!CCCC AND MOVED TO DPCOPA.INC     AUGUST 1990
!CCCC PARAMETER (IDGAR0=2*MAXPOP)
!CCCC PARAMETER (IDGAR0=3*MAXOBV)
!
      PARAMETER (IDGAR1=1)
      PARAMETER (IDGAR2=1*MAXOBV+1)
      PARAMETER (IDGAR3=2*MAXOBV+1)
      PARAMETER (IDGAR4=3*MAXOBV+1)
      PARAMETER (IDGAR5=4*MAXOBV+1)
      PARAMETER (IDGAR6=5*MAXOBV+1)
      PARAMETER (IDGAR7=6*MAXOBV+1)
      PARAMETER (IDGAR8=7*MAXOBV+1)
      PARAMETER (IDGAR9=8*MAXOBV+1)
      PARAMETER (IDGA10=9*MAXOBV+1)
      PARAMETER (IDGAG1=1)
      PARAMETER (IDGAG2=1*MAXPOP+1)
      DOUBLE PRECISION DGARBG
      COMMON/DGARB/DGARBG(IDGAR0)
!
