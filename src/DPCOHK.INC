!-----THIS IS COMMON/INCLUDE FILE DPCOHK.INC-----
!     THIS IS COMMON FOR HOUSEKEEPING
!CCCC UPDATED--OCTOBER   1993. DISTINGUISH BETWEEN MAXSTR, MAXNME
!CCCC UPDATED--OCTOBER   1999. SUPPORT FOR ROW AND VARIABLE LABELS
!CCCC UPDATED--DECEMBER  1999. SUPPORT FOR GROUP LABELS
!CCCC UPDATED--OCTOBER   2000. PUT GROUP LABEL VARIABLES IN COMMON
!CCCC UPDATED--APRIL     2020. CHANGE SOME DIMENSION TO MAXARG
!CCCC UPDATED--APRIL     2020. CHANGE SOME CHARACTER*4 TO CHARACTER*1
!CCCC UPDATED--APRIL     2021. SUPPORT FOR ALIAS COMMAND
!
!               **************************************
!               **************************************
!               **  DEFINE AND EQUIVALENCE INTEGER  **
!               **  HOUSEKEEPING                    **
!               **  VARIABLES AND ARRAYS            **
!               **************************************
!               **************************************
!
      DIMENSION IARG(MAXARG)
!CCCC OCTOBER 1993.  USE MAXNME
!CCCC DIMENSION IVSTAR(MAXSTR)
!CCCC DIMENSION IVSTOP(MAXSTR)
!CCCC DIMENSION IN(MAXSTR)
!CCCC DIMENSION IVALUE(MAXSTR)
!CCCC DIMENSION IVALU2(MAXSTR)
      DIMENSION IVSTAR(MAXNME)
      DIMENSION IVSTOP(MAXNME)
      DIMENSION IN(MAXNME)
      DIMENSION IVALUE(MAXNME)
      DIMENSION IVALU2(MAXNME)
!
      COMMON /IHOUSE/I1HOUS(5*MAXNME+MAXSTR+50)
!
      EQUIVALENCE (I1HOUS(1) ,MAXWID)
      EQUIVALENCE (I1HOUS(2) ,IWIDTH)
      EQUIVALENCE (I1HOUS(3) ,MAXWSV)
      EQUIVALENCE (I1HOUS(4) ,IWIDSV)
!CCCC EQUIVALENCE (I1HOUS(7) ,MAXARG)
      EQUIVALENCE (I1HOUS(8) ,NUMARG)
      EQUIVALENCE (I1HOUS(9) ,MAXNAM)
      EQUIVALENCE (I1HOUS(10),NUMNAM)
      EQUIVALENCE (I1HOUS(13),IWIDDC)
!
      EQUIVALENCE (I1HOUS(51) ,IARG(1))
      EQUIVALENCE (I1HOUS(MAXSTR+51),IVSTAR(1))
      EQUIVALENCE (I1HOUS(MAXNME+MAXSTR+51),IVSTOP(1))
      EQUIVALENCE (I1HOUS(2*MAXNME+MAXSTR+51),IN(1))
      EQUIVALENCE (I1HOUS(3*MAXNME+MAXSTR+51),IVALUE(1))
      EQUIVALENCE (I1HOUS(4*MAXNME+MAXSTR+51),IVALU2(1))
!
!               ****************************************
!               ****************************************
!               **  DEFINE AND EQUIVALENCE CHARACTER  **
!               **  HOUSEKEEPING                      **
!               **  VARIABLES AND ARRAYS              **
!               ****************************************
!               ****************************************
!
      CHARACTER*4 ICOM
      CHARACTER*4 ICOM2
      CHARACTER*4 ICOMLC
      CHARACTER*4 ICOML2
      CHARACTER*4 IDEFCM
!
      CHARACTER*4 IANS
      CHARACTER*4 IANSV
!CCCC CHARACTER*1 IANS
!CCCC CHARACTER*1 IANSV
!
      CHARACTER*4 IHARG
      CHARACTER*4 IHARG2
      CHARACTER*4 IARGT
!
      CHARACTER*4 IHNAME
      CHARACTER*4 IHNAM2
      CHARACTER*4 IUSE
!
      CHARACTER*4 IDEFC
!
      CHARACTER*4 IH1HOU
!
      CHARACTER*4 IANSLC
!CCCC CHARACTER*1 IANSLC
      CHARACTER*4 IHARLC
      CHARACTER*4 IHARL2
!
      CHARACTER*40 IVARLB
      CHARACTER*24 IROWLB
      CHARACTER*40 IGRPLA(MAXGLA,MAXGRP)
      CHARACTER*8  IGRPVN(MAXGRP)
!
      DIMENSION IANS(MAXSTR)
      DIMENSION IANSV(MAXSTR)
!
      DIMENSION IHARG(MAXARG)
      DIMENSION IHARG2(MAXARG)
      DIMENSION IARGT(MAXARG)
!
      DIMENSION IHNAME(MAXNME)
      DIMENSION IHNAM2(MAXNME)
      DIMENSION IUSE(MAXNME)
!
      DIMENSION IVARLB(MAXNME)
      DIMENSION IROWLB(MAXOBV)
!
      DIMENSION IDEFC(40)
!
      DIMENSION IANSLC(MAXSTR)
      DIMENSION IHARLC(MAXARG)
      DIMENSION IHARL2(MAXARG)
!
      COMMON /IHHOUS/IH1HOU(120+3*MAXSTR+5*MAXARG+3*MAXNME)
!
      EQUIVALENCE (IH1HOU(5) ,ICOM)
      EQUIVALENCE (IH1HOU(6) ,ICOM2)
      EQUIVALENCE (IH1HOU(7) ,ICOMLC)
      EQUIVALENCE (IH1HOU(8) ,ICOML2)
      EQUIVALENCE (IH1HOU(12),IDEFCM)
!
      EQUIVALENCE (IH1HOU(81),IDEFC(1))
      EQUIVALENCE (IH1HOU(121) ,IANS(1))
      EQUIVALENCE (IH1HOU(121+MAXSTR),IANSV(1))
      EQUIVALENCE (IH1HOU(121+2*MAXSTR),IANSLC(1))
!
      EQUIVALENCE (IH1HOU(121+3*MAXSTR) ,IHARG(1))
      EQUIVALENCE (IH1HOU(121+3*MAXSTR+MAXARG),IHARG2(1))
      EQUIVALENCE (IH1HOU(121+3*MAXSTR+2*MAXARG),IARGT(1))
      EQUIVALENCE (IH1HOU(121+3*MAXSTR+3*MAXARG),IHARLC(1))
      EQUIVALENCE (IH1HOU(121+3*MAXSTR+4*MAXARG),IHARL2(1))
!
      EQUIVALENCE (IH1HOU(121+3*MAXSTR+5*MAXARG),IHNAME(1))
      EQUIVALENCE (IH1HOU(121+3*MAXSTR+5*MAXARG+MAXNME),IHNAM2(1))
      EQUIVALENCE (IH1HOU(121+3*MAXSTR+5*MAXARG+2*MAXNME+1),IUSE(1))
!
      COMMON /IHHOU2/IVARLB,IROWLB
      COMMON /IHHOU3/IGRPVN, IGRPLA
!
!    2021/04: VARIABLES FOR ALIASES
!
      PARAMETER (MAXALI=30)
      CHARACTER (LEN=8)      :: IALNAM(MAXALI)
      CHARACTER (LEN=MAXSTR) :: IALIAS(MAXALI)
      COMMON/IHHOU4/NUMALI,IALNAM,IALIAS
!
!               ********************************************************
!               ********************************************************
!               **  DEFINE AND EQUIVALENCE REAL (SINGLE PRECISION FLOATI
!               **  HOUSEKEEPING
!               **  VARIABLES AND ARRAYS
!               ********************************************************
!               ********************************************************
!
      DIMENSION ARG(MAXARG)
!CCCC DIMENSION VALUE(MAXSTR)
      DIMENSION VALUE(MAXNME)
!
      COMMON /RHOUSE/R1HOUS(MAXSTR+MAXNME)
!
      EQUIVALENCE (R1HOUS(1)  ,ARG(1))
      EQUIVALENCE (R1HOUS(MAXSTR+1),VALUE(1))
!
