!-----THIS IS COMMON/INCLUDE FILE DPCOHO.INC-----
!     THIS IS COMMON FOR HOSTS
!
!CCCC UPDATED--JULY     1996. ADD "IWBFLG" VARIABLE TO SPECIFY IF
!CCCC                         DATAPLOT BEING RUN FROM THE WEB.
!CCCC UPDATED--MARCH    1997. ADD "IBROWS" VARIABLE TO SPECIFY THE
!CCCC                         DESIRED WEB BROWSER FOR THE WEB HELP
!CCCC                         COMMAND
!CCCC UPDATED--MARCH    1997. ADD "IDPURL" VARIABLE TO SPECIFY THE
!CCCC                         URL OF THE DATAPLOT REFERENCRE MANUAL
!CCCC                         FOR THE WEB HELP COMMAND
!CCCC UPDATED--APRIL    1997. ADD "IURL" VARIABLE TO SPECIFY THE
!CCCC                         URL FOR THE WEB COMMAND
!CCCC UPDATED--FEBRUARY 1998. ADD "IGUIIO" VARIABLE TO SPECIFY WHETHER
!CCCC                         THE TCL/TK SCRIPTS SHOULD USE "PIPE"
!CCCC                         I/O OR "FILE" I/O.  "FILE" I/O SEEMS
!CCCC                         TO BE NEEDED FOR WINDOWS 95.
!CCCC UPDATED--MARCH    1999. ADD "IHBURL" VARIABLE TO SPECIFY THE
!CCCC                         URL FOR THE WEB COMMAND
!
      CHARACTER*4 IHOST1
      CHARACTER*4 IHOST2
      CHARACTER*4 IHMOD1
      CHARACTER*4 IHMOD2
      CHARACTER*4 IOPSY1
      CHARACTER*4 IOPSY2
      CHARACTER*4 ICOMPI
      CHARACTER*4 ISITE
!
      COMMON /CHOST/   &
      IHOST1,IHOST2,IHMOD1,IHMOD2,IOPSY1,IOPSY2,ICOMPI,ISITE
!
!CCCC JULY 1996.  ADD FOLLOWING LINES.
!CCCC MARCH 1997.  ADD FOLLOWING LINES.
      PARAMETER(MAXURL=256)
      PARAMETER(MAXBRO=80)
      CHARACTER*4 IWBFLG
      CHARACTER*80 IBROWS
      CHARACTER*256 IDPURL
      COMMON /CHOST2/   &
      IWBFLG,IBROWS,IDPURL
!
      CHARACTER*80 IURL, IHBURL
      COMMON /CHOST3/   &
      IURL,IHBURL
      COMMON/IHOST3/NCHURL
!
      CHARACTER*4 IGUIIO
      COMMON /CHOST4/   &
      IGUIIO
