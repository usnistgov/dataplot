!
! -----EQUIVALENCE---------------------------------------
!
!     AUGUST 1992.  USE SCRATCH COMMON TO REDUCE SPACE REQUIREMENTS
!     CAUTION:  THIS IS EQUIVALENCING A CHARACTER ARRAY WITH A REAL
!     ARRAY.  SINCE THIS IS SIMPLY SCRATCH SPACE, SHOULD NOT CAUSE
!     A PROBLEM.  HOWEVER, IF YOUR COMPILER DOES NOT ALLOW THIS, DO
!     ONE OF THE FOLLOWING:
!        1) COMMENT OUT THE FOLLOWING EQUIVALENCE.  IF SPACE IS A
!           PROBLEM,  SET THE VALUE OF MAXEDC IN DPCOPA.INC
!        2) YOU CAN DE-ACTIVATE THE EDIT COMMAND BY COMMENTING
!           OUT THE CALL TO DPEDIT IN THE MAIN ROUTINE.
!
      EQUIVALENCE(CGARBG(1),ICHA(1))
      EQUIVALENCE(IGARBG(1),IPOIOL(1))
      EQUIVALENCE(IGARBG(MAXEDL+1),IPOINT(1))
      EQUIVALENCE(IGARBG(2*MAXEDL+1),ILOCC1(1))
      EQUIVALENCE(IGARBG(3*MAXEDL+1),NUMCPL(1))
