!-----THIS IS COMMON/INCLUDE FILE DPCOPM.INC-----
!     THIS IS COMMON FOR SAVING AND RESTORING PIXMAPS
!
!     UPDATED APRIL    1997.  UPDATES FOR X11 (SAVING PIXMAPS)
!
!    THESE VARIABLES ARE INITIALIZED IN "INITOD".
!
! ----------------------------------------------------
!
!     NUMPXM   - NUMBER OF PIXMAPS
!     ICURPM   - CURRENT PIXMAP
!     IPXMNC   - NUMBER OF CHARACTERS IN BASE FILE NAME
!     IPXMFL   - PIXMAP FLAG (ON OR AUTO MEANS AUTOMATICALLY SAVE
!                PIXMAP AFTER A PLOT, OFF MEANS NO AUTOMATIC SAVE)
!     IPXMFN   - ARRAY CONTAINING THE FILE NAMES OF SAVED PIXMAPS
!     IPXMCM   - ARRAY CONTAINING COMMAND THAT GENERATED SAVED PIXMAPS
!     IPXMFB   - BASE FILE NAME (USED WHEN AUTOMATIC SAVING IS ON),
!                THE COUNTER NUMPXM IS ADDED TO COMPLETE THE NAME
!
      COMMON/IPIXMP/NUMPXM,ICURPM,IPXMNC
      CHARACTER*4 IPXMFL
      CHARACTER*128 IPXMFB
      CHARACTER*128 IPXMFN
      CHARACTER*256 IPXMCM
      COMMON/CPIXMP/IPXMFL,IPXMFN(MAXPM),IPXMCM(MAXPM),IPXMFB
!
