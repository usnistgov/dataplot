!     UPDATED APRIL 1988 (CYBER) & FEBRUARY 1989 (VAX)
!     UPDATED BY ALAN HECKERT.
!     ADD IPRGR AND IRDGR TO ICOMGU SO AS TO
!     USE SEPARATE DEVICE UNITS FOR GRAPHICS AND
!     AND ALPHANUMERIC I/O.  REQUIRED FOR SOME HOSTS, FOR EXAMPLE
!     CYBER NOS/VE.  GRAPHICS TERMINAL NEEDS TO BE IN "TRANSPARENT"
!     MODE WHILE ALPHANUMERIC MODE NEEDS TO BE IN "NON-TRANSPARENT"
!     MODE.  MOST HOSTS WILL SET IPRGR AND IRDGR SAME AS IPR AND
!     IRD.
!
      COMMON /ICOMGU/IGUNIT,IPRGR,IRDGR
      COMMON /ICOMCN/IGCONT
      COMMON /ICOMPP/NUMHPP,NUMVPP,ANUMHP,ANUMVP
      COMMON /ICOMCO/IGCOLO
