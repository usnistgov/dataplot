      COMMON /ICOMBA/AGERDE,AGCODE,IGBAUD
      COMMON /ICOMSO/ISOFT,ISOFT2,ISOFT3
      COMMON /ICOMP1/IPPDE1,IPPDE2
      COMMON /ICOMP2/ICPREP,ICPOST
      COMMON /ICOMP3/NCPREP,NCPOST
