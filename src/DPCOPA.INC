!-----1. INTERNAL WORKSPACE---------------------------------------------
!
!     DEFINE INTERNAL DATA SPACE DIMENSIONS:
!           MAXOBV = THE MAXIMUM NUMBER OF OBS. PER VARIABLE
!           MAXOBW = THE MAXIMUM NUMBER OF OBS. PER WORKSPACE
!           MAXPOP = THE MAXIMUM NUMBER OF PLOT POINTS
!
!CCCC PARAMETER (MAXOBV=2048)
!CCCC PARAMETER (MAXOBW=20480)
!CCCC PARAMETER (MAXPOP=5000)
!
!CCCC PARAMETER (MAXOBV=16400)
!CCCC PARAMETER (MAXOBW=82000)
!CCCC PARAMETER (MAXPOP=16400)
!
!CCCC PARAMETER (MAXOBV=2000000)
!CCCC PARAMETER (MAXOBV=1800000)
      PARAMETER (MAXOBV=2000000)
!CCCC PARAMETER (MAXOBV=1000000)
      PARAMETER (MAXOBW=10*MAXOBV)
      PARAMETER (MAXPOP=2*MAXOBV)
!
!-----2. EDITOR/FED---------------------------------------------
!
!     DEFINE EDIT/FED DIMENSIONS (AUGUST 1992):
!           MAXEDC = THE MAXIMUM NUMBER OF CHARACTERS
!                    THAT THE EDIT/FED COMMAND CAN ACCOMODATE
!           MAXEDL = THE MAXIMUM NUMBER OF LINES
!                    THAT THE EDIT/FED COMMAND CAN ACCOMODATE
!
!CCCC THE FOLLOWING 2 LINES WERE CHANGED  JULY 1993 (JJF)
!CCCC 250K => 500K   AND   10K => 25K     JULY 1993 (JJF)
!CCCC PARAMETER (MAXEDC=250000)
!CCCC PARAMETER (MAXEDL=10000)
!CCCC PARAMETER (MAXEDC=500000)
      PARAMETER (MAXEDC=24*MAXOBV)
      PARAMETER (MAXEDL=25000)
!
!     NOTE--THESE NUMBERS CAN BE REDUCED IF SPACE IS A PROBLEM.
!           (KEEP AS MULTIPLE OF 8 TO MAINTAIN WORD BOUNDARY.) ????
!-----3. REGRESSION---------------------------------------------
!
!     DEFINE REGRESSION DIMENSIONS:
!           MAXCMP = THE MAXIMUM NUMBER OF COEFFICIENTS IN
!                    POLYNOMIAL/MULTILINEAR REGRESSION
!                    (NORMALLY, THIS SETTING IS LEFT
!                    UNCHANGED AT 35)
!
      PARAMETER (MAXCMF=35)
!
!-----4. SCRATCH ARRAYS---------------------------------------------
!
!     DEFINE SCRATCH ARRAY DIMENSIONS:
!     DANGER--THE FOLLOWING 4 SECTIONS DEFINE SCRATCH ARRAY SIZES
!             WHICH ARE CONDITIONAL ON SETTTINGS IN THE ABOVE
!             3 SECTIONS.  THE SCRATCH ARRAYS SIZES AS
!             DEFINED BELOW VIA IGARB0, IIGAR0, IG2RB0, AND IDGAR0
!             MUST BE CORRECT, OR ELSE ERRORS WILL RESULT.
!             IF YOU MAKE CHANGES IN THE ABOVE 3 SECTIONS,
!             THEN YOU MUST THINK THROUGH AND MANUALLY CHANGE
!             THE SCRATCH ARRAY SIZES BELOW.
!
!     STEP 1--ACTIVATE THE LARGER OF THE FOLLOWING 2 LINES--
!CCCC         MAY 1995.  CHAGE FROM 10*MAXOBV TO 20*MAXOBV
!
!CCCC PARAMETER (IGARB0=10*MAXOBV)
!CCCC PARAMETER (IGARB0=20*MAXOBV)
!CCCC PARAMETER (IGARB0=66*MAXOBV)
      PARAMETER (IGARB0=35*MAXOBV)
!CCCC PARAMETER (IGARB0=5*MAXPOP)  10 BY 2048
!
!     STEP 2--ACTIVATE THE LARGEST OF THE FOLLOWING 3 LINES--
!
      PARAMETER (IIGAR0=17*MAXOBV)
!CCCC PARAMETER (IIGAR0=2*MAXPOP)
!CCCC PARAMETER (IIGAR0=4*MAXEDL)
!
!CCCC PARAMETER (KGARB0=4*MAXOBV)
      PARAMETER (KGARB0=6*MAXOBV)
!
!     STEP 3--ACTIVATE THE LARGEST OF THE FOLLOWING 4 LINES--
!             46*MAXOBV ADDED APRIL 1996 TO ACCOMODATE DDS CODE
!
!CCCC PARAMETER (IG2RB0=35*MAXOBV)
!CCCC PARAMETER (IG2RB0=MAXCMF*MAXOBV)
!CCCC PARAMETER (IG2RB0=46*MAXOBV)
!CCCC PARAMETER (IG2RB0=13*MAXPOP)
!
!     STEP 4--ACTIVATE THE LARGER OF THE FOLLOWING 2 LINES--
!             MODIFIED JUNE 1994 (FROM 3*MAXOBV TO 7*MAXOBV)
!             MODIFIED APRIL 2001 (FROM 7*MAXOBV TO 10*MAXOBV)
!
!CCCC PARAMETER (IDGAR0=3*MAXOBV)
      PARAMETER (IDGAR0=10*MAXOBV)
!CCCC PARAMETER (IDGAR0=2*MAXPOP)
!
!     STEP 5--HAVE THE FOLLOWING LINE ACTIVE.
!
!CCCC THE FOLLOWING LINE WAS ADDED SEPTEMBER 1992
      PARAMETER (ICGAR0=MAXEDC)
!
! - - - NORMALLY, THE SETTINGS BELOW THIS LINE ARE LEFT UNCHANGED - -
!
!-----5. LIST/SAVE/LOOP---------------------------------------------
!
!     DEFINE LIST/SAVE/LOOP DIMENSIONS:
!           MAXLIS = THE MAXIMUM NUMBER OF LINES IN LIST/SAVE TABLE
!           MAXLIL = THE MAXIMUM NUMBER OF LINES IN LOOP TABLE
!           MAXLIP = THE MAXIMUM NUMBER OF LINES IN REPLOT TABLE
!           MAXCIS = THE MAXIMUM NUMBER OF COLUMNS IN LIST/SAVE TABLE
!                    (CURRENTLY, THIS SHOULD NOT BE GREATER THAN 80)
!           MAXCIL = THE MAXIMUM NUMBER OF COLUMNS IN LOOP TABLE
!                    (CURRENTLY, THIS SHOULD NOT BE GREATER THAN 80)
!           MAXLOO = THE MAXIMUM NUMBER OF NESTED LOOPS
!CCCC ADD FOLLOWING APRIL 1997
!           MAXPM  = THE MAXIMUM NUMBER OF PIXMAPS TO SAVE
!           MAXMAC = THE MAXIMUM NUMBER OF NESTED CALLS
!                    (IF SET > 10, NEED TO MODIFY INITFO IN
!                    DP1.FOR)
!
!CCCC THE FOLLOWING LINE WAS CHANGED APRIL 1993
!CCCC PARAMETER (MAXLIS=50)
      PARAMETER (MAXLIS=200)
      PARAMETER (MAXLIP=20)
      PARAMETER (MAXLOO=20)
!CCCC SEPTEMBER 2002.  INCREASE VALUE OF MAXLIL
!CCCC FEBRUARY  2014.  INCREASE VALUE OF MAXLIL
!CCCC PARAMETER (MAXLIL=500)
!CCCC PARAMETER (MAXLIL=1000)
!CCCC PARAMETER (MAXLIL=2000)
!CCCC PARAMETER (MAXLIL=5000)
      PARAMETER (MAXLIL=20000)
!CCCC PARAMETER (MAXCIS=80)
!CCCC PARAMETER (MAXCIS=255)
      PARAMETER (MAXCIS=1024)
!CCCC PARAMETER (MAXCIL=80)
!CCCC PARAMETER (MAXCIL=255)
!CCCC PARAMETER (MAXCIL=1024)
      PARAMETER (MAXCIL=256)
      PARAMETER (MAXPM=200)
      PARAMETER (MAXMAC=10)
!
!-----6. MATRICES---------------------------------------------
                                                                                                                                  
!     DEFINE MATRIX DIMENSIONS:
!           MAXROM = THE MAXIMUM NUMBER OF ROWS IN A MATRIX
!           MAXCOM = THE MAXIMUM NUMBER OF COLUMNS IN A MATRIX
!CCCC JANUARY 1998.  USE MAXTOM INSTEAD OF MAXROM AND MAXCOM.
!CCCC MAXROM, MAXCOM WILL BE MOVED TO DPCODA.INC AND CAN BE
!CCCC MODIFIED VIA A DIMENSION MATRIX <ROWS/COLUMNS> <VALUE>
!
!CCCC THE FOLLOWING 2 LINES WERE CHANGED NOVEMBER 1992
!CCCC AND THEN MAXROM CHANGED AGAIN      JUNE 1993
!CCCC AUGUST 1993: 6*MAXROM*MAXCOM MUST BE SMALLER THAN IG2RB0
!CCCC              AS DEFINED IN STEP 3.
!CCCC              (USUALLY 46*MAXOBV = 920,0000)
!CCCC JANUARY 1998: 6*MAXROM*MAXCOM TO 3*MAXROM*MAXCOM  (6 TO 3
!CCCC               TEMPORARY MATRICES NOW REQUIRED)
!CCCC              IF YOU WANT TO EXCEED THIS, THEN UNCOMMENT
!CCCC              THE IG2RB0 LINE HERE AND COMMENT OUT THE ONE IN
!CCCC              STEP 3.
!CCCC JANUARY 1998: MAXTOM=46*MAXOBV/3
!CCCC JULY    2019: MAXTOM=35*MAXOBV/3
!C
!CCCC PARAMETER (MAXROM=20)
!CCCC PARAMETER (MAXCOM=20)
!CCCC PARAMETER (MAXROM=100)
!CCCC PARAMETER (MAXROM=1500)
!CCCC PARAMETER (MAXROM=3000)
!CCCC PARAMETER (MAXCOM=100)
!CCCC PARAMETER (MAXTOM=INT(46.0*REAL(MAXOBV)/3.0))
      PARAMETER (MAXTOM=INT(35.0*REAL(MAXOBV)/3.0))
!CCCC PARAMETER (IG2RB0=6*MAXROM*MAXCOM)
!
!-----7. PLOT CONTROL---------------------------------------------
!
!     DEFINE PLOT CONTROL COMPONENT DIMENSIONS:
!           MAXTC  = THE MAXIMUM NUMBER OF TIC MARKS ON AN AXIS
!           MAXLG  = THE MAXIMUM NUMBER OF LEGENDS
!           MAXBX  = THE MAXIMUM NUMBER OF BOXES
!           MAXAR  = THE MAXIMUM NUMBER OF ARROWS
!           MAXSG  = THE MAXIMUM NUMBER OF SEGMENTS
!           MAXLN  = THE MAXIMUM NUMBER OF TRACES
!           MAXCH2 = THE MAXIMUM NUMBER OF CHARACTER TRACES
!           MAXFL  = THE MAXIMUM NUMBER FILL
!           MAXPT  = THE MAXIMUM NUMBER OF PATTERN
!           MAXSP  = THE MAXIMUM NUMBER OF SPIKES
!           MAXBA  = THE MAXIMUM NUMBER OF BARS
!           MAXRE  = THE MAXIMUM NUMBER OF REGIONS
!           MAXTX  = THE MAXIMUM NUMBER FOR TEXT COMMAND
!           MAXTX  = THE MAXIMUM NUMBER OF SUBREGIONS
!           MAXGRP = THE MAXIMUM NUMBER OF GROUP LABEL VARIABLES
!           MAXGR2 = THE MAXIMUM NUMBER OF CHARACTERS FOR A GROUP LABEL
!           MAXGLA = THE MAXIMUM NUMBER OF LEVELS FOR A GROUP VARIABLE
!           MAXCNL = THE MAXIMUM NUMBER OF CONTOUR LABELS
!
      PARAMETER (MAXTC=100)
      PARAMETER (MAXLG=100)
      PARAMETER (MAXBX=100)
      PARAMETER (MAXAR=100)
      PARAMETER (MAXSG=100)
      PARAMETER (MAXLN=100)
      PARAMETER (MAXCH2=100)
      PARAMETER (MAXFL=100)
      PARAMETER (MAXPT=100)
      PARAMETER (MAXSP=100)
      PARAMETER (MAXBA=100)
      PARAMETER (MAXRG=100)
      PARAMETER (MAXMR=100)
      PARAMETER (MAXTX=100)
      PARAMETER (MAXSUB=10)
!CCCC PARAMETER (MAXGRP=5)
      PARAMETER (MAXGRP=50)
      PARAMETER (MAXGR2=40)
      PARAMETER (MAXGLA=1000)
      PARAMETER (MAXCNL=100)
!
!     NOTE--CHANGING THE ABOVE DEFAULTS FROM 100 TO 50
!           SAVE ABOUT 8000 WORDS.
!           THIS CAN BE HELPFUL FOR SYSTEMS SUCH AS CDC
!           NOS THAT HAVE RESTRICTIVE MEMORY REQUIREMENTS.
!
!-----8. CHARACTER STRINGS---------------------------------------------
!
!     DEFINE CHARACTER STRING SIZES:
!           MAXCH  = THE MAXIMUN NUMBER OF CHARACTERS IN A TEXT
!                    STRING FOR A LEGEND, TITLE, LABEL, ETC.
!           MAXLG2 = THE MAXIMUN NUMBER OF CHARACTERS IN LEGEND
!
!           MAXF1  = THE TOTAL NUMBER OF CHARACTERS FOR ALL FUNCTIONS
!           MAXF2  = THE MAXIMUM NUMBER OF FUNCTIONS
!           MAXF3  = THE TOTAL NUMBER OF CHARACTERS PRINTED
!                    FOR THE LAST MODEL FITTED
!
!           MAXSTR = THE MAXIMUM NUMBER OF CHARACTERS IN A STRING
!                    (USED TO DIMENSION IANS, IANSLC, ETC.)
!           MAXARG = THE MAXIMUM NUMBER OF COMMAND LINE ARGUMENTS
!           MAXFNC = THE MAXIMUM NUMBER OF CHARACTERS FOR FILE NAMES
!           MAXNME = THE MAXIMUM NUMBER OF NAMES (PARAMETERS,
!                    VARIABLES, MATRICES)
!           MAXRCL = THE MAXIMUM NUMBER OF CHARACTERS THAT CAN BE
!                    READ FROM A DATA FILE (AS OPPOSSED TO A COMMAND LINE)
!
!CCCC THE FOLLOWING LINE WAS CHANGED AUGUST 1992
!CCCC PARAMETER (MAXCH=130)
      PARAMETER (MAXCH=200)
      PARAMETER (MAXLG2=1000)
!
!CCCC PARAMETER (MAXF1=1000)
!CCCC PARAMETER (MAXFN2=100)
!CCCC PARAMETER (MAXF3=200)
!CCCC PARAMETER (MAXF1=10000)
!CCCC PARAMETER (MAXF1=50000)
      PARAMETER (MAXF1=100000)
!CCCC PARAMETER (MAXFN2=200)
!CCCC PARAMETER (MAXF3=200)
!CCCC PARAMETER (MAXFN2=500)
      PARAMETER (MAXFN2=2000)
      PARAMETER (MAXF3=500)
!
!CCCC PARAMETER (MAXSTR=255)
      PARAMETER (MAXSTR=1024)
      PARAMETER (MAXARG=200)
      PARAMETER (MAXFNC=256)
!CCCC MAY 1997.  UP MAXIMUM NUMBER OF NAMES
!CCCC JANUARY 1998.  UP MAXIMUM NUMBER OF NAMES
!CCCC PARAMETER (MAXNME=500)
!CCCC PARAMETER (MAXNME=1000)
!CCCC PARAMETER (MAXNME=2500)
      PARAMETER (MAXNME=50000)
      PARAMETER (MAXRCL=9999)
!
!     NOTE--LENGTH OF A LINE READ IN IS STILL LIMITED TO 80 CHARACTERS
!           SINCE SOME LOCAL VARIABLES ARE STILL HARD-CODED TO 80
